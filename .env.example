# Copy this file to .env and set your Azure OpenAI target URI and key.
# Do not commit your real API key to source control.

AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2025-01-01-preview

# Optional fallback variable names:
# OPENAI_API_KEY=your_azure_openai_key_here
# OPENAI_API_BASE=https://your-resource-name.openai.azure.com/

# User storage preference:
# - Preferred: create `data/users.json` with a JSON object of username:password pairs.
#   Example file `data/users.json`:
#   {
#     "alice": "alicepass",
#     "bob": "bobpass",
#     "admin": "adminpass"
#   }
# - Fallback: environment variables `APP_USERS` or `ADMIN_USER`/`ADMIN_PASS`.
